# ============================================================
# AETHER BAGHDAD v2.0 — Environment Variables
# Copy to .env.local and fill in real values
# NEVER commit .env.local to version control
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI Layer ──────────────────────────────────────────────────
# You can provide ONE key (GROQ_API_KEY) or a pool (GROQ_API_KEY_1..10)
GROQ_API_KEY=gsk_your-groq-api-key-here
# GROQ_API_KEY_1=gsk_...
# GROQ_API_KEY_2=gsk_...

# ── Astronomy APIs ────────────────────────────────────────────
NASA_API_KEY=your-nasa-api-key-here
# You can provide ONE key (ASTROLOGY_API_KEY) or a pool (ASTROLOGY_API_KEY_1..10)
ASTROLOGY_API_KEY=your-astrology-api-key-here
# ASTROLOGY_API_KEY_1=...

# ── Geolocation ───────────────────────────────────────────────
# Pools supported: OPENCAGE_API_KEY_1..10, TIMEZONEDB_API_KEY_1..10
OPENCAGE_API_KEY=your-opencage-api-key-here
TIMEZONEDB_API_KEY=your-timezonedb-api-key-here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://aether-baghdad.vercel.app

# ── Security ──────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50
